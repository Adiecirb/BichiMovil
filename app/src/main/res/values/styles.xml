<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="MainButton" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/white</item>
        <item name="android:textColor">@color/mainBackground</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="MainText" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/pure_white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="MainTextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/white</item>
        <item name="hintTextColor">@color/user_input_purple</item>
        <item name="android:textColorHint">@color/user_input_purple</item>
        <item name="boxStrokeColor">@color/user_input_purple</item>
    </style>

    <style name="UserInputText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/user_input_purple</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="LinkTextRegister">
        <item name="android:textColor">@color/navy_blue_link</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="LinkTextReset">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
